generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WhatsAppSession {
  id        String   @id @default(cuid())
  key       String   @unique
  data      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Group {
  id                 String           @id
  name               String
  participantCount   Int              @default(0)
  lastSynced         DateTime         @default(now())
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  moduleNumber       Int?
  // "car" (Class 5 theory cohort, default — phases 1-4 over 12 modules)
  // or "truck" (Class 1, intake-style; no module phases). Drives which
  // tab the group lives under on /groups and which teacher's Teamup
  // calendar receives scheduled events.
  vehicleType        String           @default("car")
  lastMessageDate    DateTime?
  lastMessagePreview String?
  attendanceSheet    AttendanceSheet?
  members            GroupMember[]
}

model Contact {
  id         String             @id
  phone      String
  name       String?
  pushName   String?
  lastSynced DateTime           @default(now())
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  records    AttendanceRecord[]
  groups     GroupMember[]
}

model GroupMember {
  id           String   @id @default(cuid())
  groupId      String
  contactId    String
  phone        String
  isAdmin      Boolean  @default(false)
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  contact      Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  group        Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, contactId])
  @@index([groupId])
  @@index([phone])
}

model AttendanceSheet {
  id        String             @id @default(cuid())
  groupId   String             @unique
  name      String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  records   AttendanceRecord[]
  group     Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model AttendanceRecord {
  id                String          @id @default(cuid())
  attendanceSheetId String
  contactId         String
  status            String          @default("absent")
  notes             String?
  date              DateTime        @default(now())
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  contact           Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  attendanceSheet   AttendanceSheet @relation(fields: [attendanceSheetId], references: [id], onDelete: Cascade)

  @@unique([attendanceSheetId, contactId, date])
}

model ZoomAttendance {
  id             String   @id @default(cuid())
  groupId        String
  meetingUUID    String
  meetingDate    DateTime
  moduleNumber   Int?
  matchedRecords String
  absentRecords  String
  unmatchedZoom  String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([groupId, meetingUUID])
}

model ZoomNameMatch {
  id            String   @id @default(cuid())
  zoomName      String
  whatsappPhone String
  whatsappName  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([zoomName, whatsappPhone])
}

// Note: CertificateSettings also stores the SAAQ Class 1 training
// addresses used by the truck service contract PDF. Kept here (rather
// than a new table) because admins already manage school-side info on
// the existing certificate settings page.
model CertificateSettings {
  id                    String   @id @default("default")
  nextContractNumber    Int      @default(1)
  nextAttestationNumber Int      @default(1)
  attestationNumberEnd  Int      @default(9999)
  schoolName            String   @default("École de Conduite Qazi")
  schoolAddress         String   @default("786 rue Jean-Talon Ouest")
  schoolCity            String   @default("Montréal")
  schoolProvince        String   @default("QC")
  schoolPostalCode      String   @default("H3N 1S2")
  schoolNumber          String   @default("L526")
  // SAAQ Class 1 service contract — addresses (Art. 83 (b)(c)(e))
  truckTheoryAddress    String   @default("")
  truckRoadAddress      String   @default("")
  truckCircuitAddress   String   @default("")
  // Optional school phone shown in the contract parties block
  schoolPhone           String   @default("514 274 6948")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model TeacherPhone {
  id            String   @id @default(cuid())
  subcalendarId Int      @unique
  name          String
  phone         String
  // Optional key that groups multiple subcalendars together when they
  // belong to the same physical teacher. Example: Fayyaz has both
  // "Fayyaz Car-Theory" and "Fayyaz Truck" calendars; setting
  // teacherKey="fayyaz" on both rows lets the scheduling duplicate
  // check treat them as one teacher (a truck class at 5pm blocks a
  // car class at 5pm and vice versa).
  teacherKey    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([teacherKey])
}

model MessageLog {
  id        String   @id @default(cuid())
  type      String
  to        String
  toName    String?
  message   String
  status    String   @default("sent")
  error     String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model ClassAttendance {
  id        String   @id @default(cuid())
  eventId   String   @unique
  present   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Digital signatures captured when students check in to in-car classes
// (Sign-In Mode on /scheduling). Used both for live attendance and to
// generate the SAAQ-style attendance booklet PDF for compliance.
model ClassSignature {
  id               String   @id @default(cuid())
  eventId          String   // Teamup event ID
  studentPhone     String
  studentName      String
  // Optional human-readable session label captured at sign time, e.g.
  // "Session 5 (In-Car)" — survives even if Teamup event is later edited.
  sessionLabel     String?
  // Module / sortie number when parseable from event title — drives the
  // PDF row mapping.
  moduleNumber     Int?
  sortieNumber     Int?
  // base64 data URL (e.g. "data:image/png;base64,...") of the signature
  signatureDataUrl String
  signedAt         DateTime @default(now())

  @@index([eventId])
  @@index([studentPhone])
  @@unique([eventId, studentPhone])
}

model Student {
  id               String        @id @default(cuid())
  licenceNumber    String?       @unique
  name             String
  phone            String?
  phoneAlt         String?
  email            String?
  avatarImage      String? // base64 student photo for profile pages
  address          String?
  apartment        String?
  municipality     String?
  province         String?
  postalCode       String?
  registrationDate String?
  expiryDate       String?
  module1Date      String?
  module2Date      String?
  module3Date      String?
  module4Date      String?
  module5Date      String?
  module6Date      String?
  sortie1Date      String?
  sortie2Date      String?
  module7Date      String?
  sortie3Date      String?
  sortie4Date      String?
  module8Date      String?
  sortie5Date      String?
  sortie6Date      String?
  module9Date      String?
  sortie7Date      String?
  sortie8Date      String?
  module10Date     String?
  sortie9Date      String?
  sortie10Date     String?
  module11Date     String?
  sortie11Date     String?
  sortie12Date     String?
  sortie13Date     String?
  module12Date     String?
  sortie14Date     String?
  sortie15Date     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  certificates     Certificate[]

  @@index([name])
  @@index([phone])
}

model Certificate {
  id                String   @id @default(cuid())
  studentId         String
  certificateType   String
  contractNumber    String?
  attestationNumber String?
  generatedAt       DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model InvoiceSettings {
  id                String   @id @default("default")
  nextInvoiceNumber Int      @default(1)
  invoicePrefix     String   @default("INV")
  defaultGstRate    Float    @default(5.0)
  defaultQstRate    Float    @default(9.975)
  gstNumber         String   @default("")
  qstNumber         String   @default("")
  taxesEnabled      Boolean  @default(true)
  senderEmail       String   @default("")
  notes             String   @default("Merci pour votre confiance! / Thank you for your business!")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Invoice {
  id                String   @id @default(cuid())
  invoiceNumber     String   @unique
  studentName       String
  studentAddress    String?
  studentCity       String?
  studentProvince   String?
  studentPostalCode String?
  studentPhone      String?
  studentEmail      String?
  invoiceDate       String
  dueDate           String?
  lineItems         String
  subtotal          Float
  gstAmount         Float    @default(0)
  qstAmount         Float    @default(0)
  total             Float
  notes             String?
  paymentMethod     String?
  paymentStatus     String   @default("unpaid")
  cloverOrderId     String?
  cloverPaymentUrl  String?
  cloverPaid        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  remainingBalance  Float?

  @@index([studentName])
  @@index([invoiceNumber])
}

model InvoiceService {
  id           String   @id @default(cuid())
  name         String
  description  String?
  price        Float
  vehicleType  String   @default("both")
  taxInclusive Boolean  @default(true)
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([vehicleType])
}

model InvoicePackage {
  id           String              @id @default(cuid())
  name         String
  vehicleType  String              @default("both")
  totalPrice   Float
  taxInclusive Boolean             @default(true)
  isActive     Boolean             @default(true)
  sortOrder    Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  instalments  PackageInstalment[]

  @@index([vehicleType])
}

model PackageInstalment {
  id               String         @id @default(cuid())
  packageId        String
  instalmentNumber Int
  name             String
  amount           Float
  sortOrder        Int            @default(0)
  package          InvoicePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
}

model ScheduledMessage {
  id             String    @id @default(cuid())
  groupId        String
  message        String
  scheduledAt    DateTime
  memberPhones   String
  moduleNumber   Int?
  classDateISO   String?
  classTime      String?
  isGroupMessage Boolean   @default(false)
  status         String    @default("pending")
  sentAt         DateTime?
  error          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, scheduledAt])
}

model AnalyticsChat {
  id        String                 @id @default(cuid())
  title     String                 @default("New Chat")
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  messages  AnalyticsChatMessage[]
}

model AnalyticsChatMessage {
  id        String        @id @default(cuid())
  chatId    String
  role      String // "user" or "assistant"
  content   String
  chartData String? // JSON chart config for assistant messages
  createdAt DateTime      @default(now())
  chat      AnalyticsChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
}

model StudentRegistration {
  id             String    @id @default(cuid())
  status         String    @default("pending_scan")
  // "car" (Class 5, default — anyone can self-register) or "truck"
  // (Classes 1 & 3 — admin-only). Public registrations always come in
  // as "car" because the public Truck flow is just a contact card.
  vehicleType    String    @default("car")
  fullName       String?
  phoneNumber    String?
  permitNumber   String?
  permitExpiry   String?  // YYYY-MM-DD extracted via OCR from the licence
  fullAddress    String?
  city           String?
  postalCode     String?
  province       String?
  dob            String?
  email          String?
  permitImage    String? // base64 permit photo
  idImage        String? // base64 ID photo
  avatarImage    String? // base64 selfie / profile photo
  signatureImage String? // base64 signature
  medical        String? // JSON: SAAQ 6224A self-declaration { conditions:number[], none:bool, attestedAt:string }

  // Clover auth-then-capture payment state for the $250 first installment.
  paymentChargeId     String?   // Clover charge id (auth created at submit time)
  paymentStatus       String?   // 'authorized' | 'captured' | 'voided' | 'failed'
  paymentLast4        String?   // last 4 digits, for display in admin
  paymentBrand        String?   // "visa", "mastercard", etc.
  paymentAmount       Int?      // cents — typically 25000 ($250)
  paymentAuthorizedAt DateTime?
  paymentCapturedAt   DateTime?
  paymentError        String?   // last error from Clover

  source         String? // "qr", "online-registration", etc.

  // ── Truck (Class 1 RSEP) contract fields ─────────────────────────────
  // Only populated when vehicleType="truck" — used to assemble the
  // SAAQ-compliant service contract PDF (Article 83). Three SAAQ
  // consents are recorded independently rather than rolled into the
  // single "terms" agreement the car flow uses.
  consentSaaqTransmission Boolean   @default(false)
  consentFileTransfer     Boolean   @default(false)
  consentContactInfo      Boolean   @default(false)
  signedAtPlace           String?   // city where the student signed
  firstCourseDate         String?   // ISO YYYY-MM-DD (Section 04)
  maxCompletionDate       String?   // firstCourseDate + 18 months
  contractNumber          String?   @unique
  // Counter-signature by the school's authorized representative —
  // captured in the admin UI after the student submits.
  repSignatureImage       String?   // base64 PNG data URL
  repSignerName           String?
  repSignedAt             DateTime?
  expiresAt      DateTime
  submittedAt    DateTime?
  confirmedAt    DateTime?
  externalId     Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
}

model Exam {
  id            String        @id @default(cuid())
  code          String        @unique
  groupId       String
  groupName     String
  active        Boolean       @default(true)
  questionOrder String        // JSON array of shuffled question indices
  createdAt     DateTime      @default(now())
  expiresAt     DateTime      // exam link expiry
  attempts      ExamAttempt[]

  @@index([code])
  @@index([groupId])
}

model ExamAttempt {
  id            String    @id @default(cuid())
  examId        String
  studentName   String
  studentPhone  String?
  answers       String    // JSON: { questionIndex: selectedAnswer }
  score         Int?
  passed        Boolean?
  tabSwitches   Int       @default(0)
  startedAt     DateTime  @default(now())
  submittedAt   DateTime?
  timeExpired   Boolean   @default(false)
  exam          Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@unique([examId, studentName])
}

model AppPreference {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model TeamupEventSnapshot {
  id        String   @id @default(cuid())
  eventId   String   @unique
  title     String
  startDt   String
  endDt     String
  notes     String   @default("")
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

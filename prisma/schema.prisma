generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WhatsAppSession {
  id        String   @id @default(cuid())
  key       String   @unique
  data      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Group {
  id                 String           @id
  name               String
  participantCount   Int              @default(0)
  lastSynced         DateTime         @default(now())
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  moduleNumber       Int?
  lastMessageDate    DateTime?
  lastMessagePreview String?
  attendanceSheet    AttendanceSheet?
  members            GroupMember[]
}

model Contact {
  id         String             @id
  phone      String
  name       String?
  pushName   String?
  lastSynced DateTime           @default(now())
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  records    AttendanceRecord[]
  groups     GroupMember[]
}

model GroupMember {
  id           String   @id @default(cuid())
  groupId      String
  contactId    String
  phone        String
  isAdmin      Boolean  @default(false)
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  contact      Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  group        Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, contactId])
  @@index([groupId])
  @@index([phone])
}

model AttendanceSheet {
  id        String             @id @default(cuid())
  groupId   String             @unique
  name      String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  records   AttendanceRecord[]
  group     Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model AttendanceRecord {
  id                String          @id @default(cuid())
  attendanceSheetId String
  contactId         String
  status            String          @default("absent")
  notes             String?
  date              DateTime        @default(now())
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  contact           Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  attendanceSheet   AttendanceSheet @relation(fields: [attendanceSheetId], references: [id], onDelete: Cascade)

  @@unique([attendanceSheetId, contactId, date])
}

model ZoomAttendance {
  id             String   @id @default(cuid())
  groupId        String
  meetingUUID    String
  meetingDate    DateTime
  moduleNumber   Int?
  matchedRecords String
  absentRecords  String
  unmatchedZoom  String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([groupId, meetingUUID])
}

model ZoomNameMatch {
  id            String   @id @default(cuid())
  zoomName      String
  whatsappPhone String
  whatsappName  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([zoomName, whatsappPhone])
}

model CertificateSettings {
  id                    String   @id @default("default")
  nextContractNumber    Int      @default(1)
  nextAttestationNumber Int      @default(1)
  attestationNumberEnd  Int      @default(9999)
  schoolName            String   @default("École de Conduite Qazi")
  schoolAddress         String   @default("786 rue Jean-Talon Ouest")
  schoolCity            String   @default("Montréal")
  schoolProvince        String   @default("QC")
  schoolPostalCode      String   @default("H3N 1S2")
  schoolNumber          String   @default("L526")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model TeacherPhone {
  id            String   @id @default(cuid())
  subcalendarId Int      @unique
  name          String
  phone         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MessageLog {
  id        String   @id @default(cuid())
  type      String
  to        String
  toName    String?
  message   String
  status    String   @default("sent")
  error     String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model ClassAttendance {
  id        String   @id @default(cuid())
  eventId   String   @unique
  present   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id               String        @id @default(cuid())
  licenceNumber    String?       @unique
  name             String
  phone            String?
  phoneAlt         String?
  address          String?
  municipality     String?
  province         String?
  postalCode       String?
  registrationDate String?
  expiryDate       String?
  module1Date      String?
  module2Date      String?
  module3Date      String?
  module4Date      String?
  module5Date      String?
  module6Date      String?
  sortie1Date      String?
  sortie2Date      String?
  module7Date      String?
  sortie3Date      String?
  sortie4Date      String?
  module8Date      String?
  sortie5Date      String?
  sortie6Date      String?
  module9Date      String?
  sortie7Date      String?
  sortie8Date      String?
  module10Date     String?
  sortie9Date      String?
  sortie10Date     String?
  module11Date     String?
  sortie11Date     String?
  sortie12Date     String?
  sortie13Date     String?
  module12Date     String?
  sortie14Date     String?
  sortie15Date     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  certificates     Certificate[]

  @@index([name])
  @@index([phone])
}

model Certificate {
  id                String   @id @default(cuid())
  studentId         String
  certificateType   String
  contractNumber    String?
  attestationNumber String?
  generatedAt       DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model InvoiceSettings {
  id                String   @id @default("default")
  nextInvoiceNumber Int      @default(1)
  invoicePrefix     String   @default("INV")
  defaultGstRate    Float    @default(5.0)
  defaultQstRate    Float    @default(9.975)
  gstNumber         String   @default("")
  qstNumber         String   @default("")
  taxesEnabled      Boolean  @default(true)
  senderEmail       String   @default("")
  notes             String   @default("Merci pour votre confiance! / Thank you for your business!")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Invoice {
  id                String   @id @default(cuid())
  invoiceNumber     String   @unique
  studentName       String
  studentAddress    String?
  studentCity       String?
  studentProvince   String?
  studentPostalCode String?
  studentPhone      String?
  studentEmail      String?
  invoiceDate       String
  dueDate           String?
  lineItems         String
  subtotal          Float
  gstAmount         Float    @default(0)
  qstAmount         Float    @default(0)
  total             Float
  notes             String?
  paymentMethod     String?
  paymentStatus     String   @default("unpaid")
  cloverOrderId     String?
  cloverPaymentUrl  String?
  cloverPaid        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  remainingBalance  Float?

  @@index([studentName])
  @@index([invoiceNumber])
}

model InvoiceService {
  id           String   @id @default(cuid())
  name         String
  description  String?
  price        Float
  vehicleType  String   @default("both")
  taxInclusive Boolean  @default(true)
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([vehicleType])
}

model InvoicePackage {
  id           String              @id @default(cuid())
  name         String
  vehicleType  String              @default("both")
  totalPrice   Float
  taxInclusive Boolean             @default(true)
  isActive     Boolean             @default(true)
  sortOrder    Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  instalments  PackageInstalment[]

  @@index([vehicleType])
}

model PackageInstalment {
  id               String         @id @default(cuid())
  packageId        String
  instalmentNumber Int
  name             String
  amount           Float
  sortOrder        Int            @default(0)
  package          InvoicePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
}

model ScheduledMessage {
  id             String    @id @default(cuid())
  groupId        String
  message        String
  scheduledAt    DateTime
  memberPhones   String
  moduleNumber   Int?
  classDateISO   String?
  classTime      String?
  isGroupMessage Boolean   @default(false)
  status         String    @default("pending")
  sentAt         DateTime?
  error          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, scheduledAt])
}

model AnalyticsChat {
  id        String                 @id @default(cuid())
  title     String                 @default("New Chat")
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  messages  AnalyticsChatMessage[]
}

model AnalyticsChatMessage {
  id        String        @id @default(cuid())
  chatId    String
  role      String // "user" or "assistant"
  content   String
  chartData String? // JSON chart config for assistant messages
  createdAt DateTime      @default(now())
  chat      AnalyticsChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
}

model StudentRegistration {
  id             String    @id @default(cuid())
  status         String    @default("pending_scan")
  fullName       String?
  phoneNumber    String?
  permitNumber   String?
  fullAddress    String?
  city           String?
  postalCode     String?
  province       String?
  dob            String?
  email          String?
  permitImage    String? // base64 permit photo
  idImage        String? // base64 ID photo
  signatureImage String? // base64 signature
  source         String? // "qr", "online-registration", etc.
  expiresAt      DateTime
  submittedAt    DateTime?
  confirmedAt    DateTime?
  externalId     Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
}

model AppPreference {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model TeamupEventSnapshot {
  id        String   @id @default(cuid())
  eventId   String   @unique
  title     String
  startDt   String
  endDt     String
  notes     String   @default("")
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

# Platform lives at qazidrivingschool.ca. Marketing site is a separate
# Cloudflare Pages deployment on qazidriving.ca and reaches this server
# via cross-origin POSTs to /api/register (see middleware.ts CORS).
qazidrivingschool.ca, www.qazidrivingschool.ca {
	encode gzip zstd
	reverse_proxy app:3000
}

# Student LMS. Same Next.js app — middleware rewrites this host into the
# /study section and exposes only the /api/lms student APIs.
study.qazidriving.ca {
	encode gzip zstd
	reverse_proxy app:3000
}
